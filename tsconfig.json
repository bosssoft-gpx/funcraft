{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "types": ["vitest/globals"],
    "strict": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": true,
    "declarationDir": "types",
    "target": "ES2019",
    "module": "ESNext",
    "skipLibCheck": true,
    "baseUrl": "./",
    "moduleResolution": "Node",
    "paths": {
      "src": ["./src"],
      "src/*": ["./src/*"]
    },
    "allowSyntheticDefaultImports": true
  },
  "include": ["**/*.ts", "**/*.tsx","**/*.d.ts"],
  "exclude": ["node_modules", "es", "lib"]
}
